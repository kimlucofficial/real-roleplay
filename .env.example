# Vercel production URL, không có dấu / cuối
NEXTAUTH_URL=https://realroleplay.net
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Discord OAuth app
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_PUBLIC_KEY=your_discord_app_public_key
DISCORD_GUILD_ID=optional_guild_id
ALLOWED_ADMIN_IDS=comma,separated,discord,user,ids

# Aiven MySQL - dùng 1 database duy nhất: defaultdb
# Dán link Aiven vào đây, có ?ssl-mode=REQUIRED vẫn chạy OK, code sẽ tự xử lý đúng chuẩn MySQL2.
DATABASE_URL=mysql://avnadmin:PASSWORD@HOST:27393/defaultdb?ssl-mode=REQUIRED

# Discord bot xử lý approve/reject trên Railway/VPS
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=channel_receive_whitelist_embed
WHITELIST_ROLE_ID=role_id_after_approved


# Discord bot - Welcome System (tách riêng, không dùng chung DISCORD_CHANNEL_ID whitelist)
WELCOME_CHANNEL_ID=channel_id_gui_welcome

# Discord bot - Ticket System (tách riêng để tránh nhầm whitelist)
# TICKET_PANEL_CHANNEL_ID: nếu điền, bot sẽ tự đăng bảng ticket khi khởi động. Không bắt buộc nếu dùng /ticketpanel.
TICKET_PANEL_CHANNEL_ID=channel_id_dang_bang_ticket
TICKET_SUPPORT_CATEGORY_ID=category_id_support
TICKET_BUG_CATEGORY_ID=category_id_bao_loi
TICKET_STAFF_ROLE_ID=role_id_staff_duoc_xem_ticket
