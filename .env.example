# Vercel production URL, không có dấu / cuối
NEXTAUTH_URL=https://realroleplay.net
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Discord OAuth app
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_PUBLIC_KEY=your_discord_app_public_key
DISCORD_GUILD_ID=optional_guild_id
ALLOWED_ADMIN_IDS=comma,separated,discord,user,ids
# Tuỳ chọn: set role Discord được vào /admin. Cần DISCORD_GUILD_ID + DISCORD_BOT_TOKEN đúng.
ADMIN_ROLE_IDS=comma,separated,discord,role,ids

# Railway MySQL
# Nếu website/bot chạy cùng Railway project với MySQL, Railway tự có MYSQL_URL.
# Nếu chạy ngoài Railway (VD: Vercel), dùng MYSQL_PUBLIC_URL hoặc copy Public URL của Railway vào DATABASE_URL.
MYSQL_URL=mysql://root:ETaBJMIyhSqlvbgbHEzBQvZpFNifNHFq@nozomi.proxy.rlwy.net:27197/railway
# MYSQL_PUBLIC_URL=mysql://root:PASSWORD@HOST.proxy.rlwy.net:PORT/railway
# DATABASE_URL=mysql://root:PASSWORD@HOST.proxy.rlwy.net:PORT/railway
MYSQL_SSL=false

# Discord bot xử lý approve/reject trên Railway/VPS
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=channel_receive_whitelist_embed
WHITELIST_ROLE_ID=role_id_after_approved

# Ticket system Discord bot
TICKET_PANEL_CHANNEL_ID=channel_send_ticket_panel
