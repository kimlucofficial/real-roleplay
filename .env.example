# Vercel production URL, không có dấu / cuối
NEXTAUTH_URL=https://realroleplay.net
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Discord OAuth app
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_PUBLIC_KEY=your_discord_app_public_key
DISCORD_GUILD_ID=optional_guild_id
ALLOWED_ADMIN_IDS=comma,separated,discord,user,ids

# Aiven MySQL - dùng 1 database duy nhất: defaultdb
# Dán link Aiven vào đây, có ?ssl-mode=REQUIRED vẫn chạy OK, code sẽ tự xử lý đúng chuẩn MySQL2.
DATABASE_URL=mysql://avnadmin:PASSWORD@HOST:27393/defaultdb?ssl-mode=REQUIRED
